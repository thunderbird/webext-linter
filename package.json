{
  "name": "@thunderbirdops/webext-linter",
  "version": "1.7.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Verifies Thunderbird WebExtensions against the annotated WebExtension API schemas and ATN review policies. ",
  "keywords": [
    "thunderbird",
    "webextension",
    "mailextension",
    "add-on",
    "review",
    "linter",
    "manifest",
    "validation"
  ],
  "homepage": "https://github.com/thunderbird/webext-linter#readme",
  "bugs": "https://github.com/thunderbird/webext-linter/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thunderbird/webext-linter.git"
  },
  "license": "MPL-2.0",
  "author": "John Bieling <john@thunderbird.net>",
  "type": "module",
  "main": "src/cli.js",
  "bin": {
    "webext-linter": "verify.js"
  },
  "files": [
    "src",
    "verify.js",
    "assets/registry.yaml",
    "assets/library-blocks.yaml",
    "assets/webext-facts.yaml",
    "assets/schema-annotations",
    "assets/llm",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "help": "node verify.js --help",
    "verify": "node verify.js",
    "lint": "eslint src *.js",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"*.js\"",
    "test": "node tests/run-tests.js && node --test tests/unit/*.test.js",
    "test:addons": "node tests/run-tests.js",
    "test:unit": "node --test tests/unit/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@babel/parser": "^8.0.4",
    "@babel/traverse": "^8.0.4",
    "@babel/types": "^8.0.4",
    "adm-zip": "^0.5.18",
    "ajv": "^8.17.1",
    "eslint": "^10.6.0",
    "franc-min": "^6.2.0",
    "json5": "^2.2.3",
    "jsonc-parser": "^3.3.1",
    "obfuscation-detector": "^3.0.0",
    "openai": "^6.45.0",
    "parse5": "^8.0.1",
    "postcss": "^8.5.16",
    "postcss-value-parser": "^4.2.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "prettier": "^3.9.4"
  },
  "engines": {
    "node": ">=20"
  }
}
