{
  "manifest_version": 3,
  "name": "All Checks Demo",
  "version": "1.0",
  "permissions": ["clipboardWrite", "bogusPermission"],
  "host_permissions": ["<all_urls>"],
  "background": { "scripts": ["background.js"] },
  "content_scripts": [
    { "matches": ["*://*/*"], "js": ["content.js", "missing.js"] }
  ],
  "weirdTopLevelKey": true,
  "browser_specific_settings": { "gecko": { "strict_min_version": "128.0" } }
}
