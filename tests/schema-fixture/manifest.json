[
  {
    "namespace": "manifest",
    "applicationVersion": "128.0",
    "types": [
      {
        "id": "ManifestBase",
        "type": "object",
        "properties": {
          "manifest_version": { "type": "integer", "enum": [3] },
          "name": { "type": "string" },
          "version": { "type": "string" },
          "description": { "type": "string" },
          "browser_specific_settings": { "type": "object" }
        }
      },
      {
        "id": "WebExtensionManifest",
        "type": "object",
        "additionalProperties": { "$ref": "UnrecognizedProperty" },
        "properties": {
          "permissions": { "type": "array" },
          "optional_permissions": { "type": "array" },
          "host_permissions": { "type": "array" },
          "default_locale": { "type": "string" },
          "icons": { "type": "object" },
          "background": { "type": "object" },
          "options_ui": { "type": "object" },
          "action": { "type": "object" },
          "content_scripts": { "type": "array" },
          "compose_scripts": {
            "type": "array",
            "annotations": [
              { "additional_properties": { "required_permissions": ["compose"] } }
            ]
          },
          "message_display_scripts": {
            "type": "array",
            "annotations": [
              {
                "additional_properties": {
                  "required_permissions": ["messagesModify"]
                }
              },
              {
                "max_strict_version": "153",
                "note": "Before Thunderbird 154, message_display_scripts also required the \"scripting\" permission to inject; the requirement was removed in 154.",
                "additional_properties": {
                  "required_permissions": ["scripting"]
                }
              }
            ]
          },
          "experiment_apis": { "type": "object" }
        }
      },
      {
        "id": "PermissionNoPrompt",
        "type": "string",
        "enum": ["storage", "alarms"]
      },
      {
        "id": "OptionalPermission",
        "choices": [
          { "$ref": "PermissionNoPrompt" },
          {
            "type": "string",
            "enum": [
              "clipboardRead",
              "clipboardWrite",
              "geolocation",
              "nativeMessaging",
              "notifications",
              "messagesModify",
              "scripting"
            ]
          }
        ]
      },
      {
        "id": "Permission",
        "choices": [
          { "$ref": "PermissionNoPrompt" },
          { "$ref": "OptionalPermission" }
        ]
      }
    ]
  }
]
