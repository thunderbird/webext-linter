[
  {
    "namespace": "manifest",
    "types": [
      {
        "$extend": "WebExtensionManifest",
        "properties": {
          "compose_scripts": {
            "annotations": [
              {
                "additional_properties": {
                  "required_permissions": [
                    "compose"
                  ]
                }
              }
            ]
          },
          "message_display_scripts": {
            "annotations": [
              {
                "min_strict_version": "154",
                "additional_properties": {
                  "required_permissions": [
                    "messagesModify"
                  ]
                }
              },
              {
                "max_strict_version": "153",
                "additional_properties": {
                  "required_permissions": [
                    "messagesModify",
                    "scripting"
                  ]
                }
              }
            ]
          }
        }
      }
    ]
  }
]